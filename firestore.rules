rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validLobbyPayload(gameId) {
      return request.resource.data.payload.keys().hasOnly(['gameId', 'displayName'])
        && request.resource.data.payload.gameId == gameId
        && request.resource.data.payload.displayName is string
        && request.resource.data.payload.displayName.size() >= 1
        && request.resource.data.payload.displayName.size() <= 30;
    }

    function validConfiguredPayload(gameId) {
      return request.resource.data.payload.keys().hasOnly(['gameId', 'princessId', 'ready'])
        && request.resource.data.payload.gameId == gameId
        && request.resource.data.payload.princessId is string
        && request.resource.data.payload.princessId.size() >= 1
        && request.resource.data.payload.ready is bool;
    }

    function validDealPayload(gameId) {
      return request.resource.data.payload.keys().hasOnly(['gameId', 'seed', 'roundIds', 'hands'])
        && request.resource.data.payload.gameId == gameId
        && request.resource.data.payload.seed is string
        && request.resource.data.payload.roundIds is list
        && request.resource.data.payload.roundIds.size() == 5
        && request.resource.data.payload.hands is map;
    }

    function validPassPayload(gameId) {
      return request.resource.data.payload.keys().hasOnly(['gameId', 'cards'])
        && request.resource.data.payload.gameId == gameId
        && request.resource.data.payload.cards is list
        && request.resource.data.payload.cards.size() >= 1
        && request.resource.data.payload.cards.size() <= 3;
    }

    function validRetractionPayload(gameId) {
      return request.resource.data.payload.keys().hasOnly(['gameId'])
        && request.resource.data.payload.gameId == gameId;
    }

    function validPlayPayload(gameId) {
      return request.resource.data.payload.keys().hasOnly(['gameId', 'card'])
        && request.resource.data.payload.gameId == gameId
        && request.resource.data.payload.card is map;
    }

    function validRoundActionPayload(gameId) {
      return request.resource.data.payload.keys().hasOnly(['gameId', 'card'])
        && request.resource.data.payload.gameId == gameId
        && request.resource.data.payload.card is map;
    }

    function validSuitRevealPayload(gameId) {
      return request.resource.data.payload.keys().hasOnly(['gameId', 'suit'])
        && request.resource.data.payload.gameId == gameId
        && request.resource.data.payload.suit in ['fairies', 'queens', 'princes', 'pets'];
    }

    function validHalfSelectionPayload(gameId) {
      return request.resource.data.payload.keys().hasOnly(['gameId', 'cards'])
        && request.resource.data.payload.gameId == gameId
        && request.resource.data.payload.cards is list
        && request.resource.data.payload.cards.size() >= 5
        && request.resource.data.payload.cards.size() <= 6;
    }

    function validPowerPayload(gameId) {
      return request.resource.data.payload.keys().hasOnly(['gameId', 'powerId', 'targetUid', 'card', 'cards', 'suit'])
        && request.resource.data.payload.keys().hasAll(['gameId', 'powerId'])
        && request.resource.data.payload.gameId == gameId
        && request.resource.data.payload.powerId is string;
    }

    function validEvent(gameId) {
      return request.resource.data.keys().hasOnly([
          'type', 'payload', 'actorUid', 'clientSeq', 'createdAt',
          'schemaVersion', 'reducerVersion'
        ])
        && request.resource.data.type in ['game/created', 'game/rematched', 'player/joined', 'player/configured', 'game/dealt', 'pass/submitted', 'pass/retracted', 'card/played', 'power/activated', 'power/contributed', 'power/declined', 'round/card-set-aside', 'round/pass-submitted', 'round/suit-revealed', 'round/half-selected', 'round/gift-submitted']
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.clientSeq is int
        && request.resource.data.clientSeq > 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.schemaVersion == 1
        && request.resource.data.reducerVersion == 1
        && (
          (request.resource.data.type in ['game/created', 'player/joined'] && validLobbyPayload(gameId))
          || (request.resource.data.type == 'game/rematched' && validRetractionPayload(gameId))
          || (request.resource.data.type == 'player/configured' && validConfiguredPayload(gameId))
          || (request.resource.data.type == 'game/dealt' && validDealPayload(gameId))
          || (request.resource.data.type == 'pass/submitted' && validPassPayload(gameId))
          || (request.resource.data.type == 'pass/retracted' && validRetractionPayload(gameId))
          || (request.resource.data.type == 'card/played' && validPlayPayload(gameId))
          || (request.resource.data.type in ['round/card-set-aside', 'round/pass-submitted', 'round/gift-submitted'] && validRoundActionPayload(gameId))
          || (request.resource.data.type == 'round/suit-revealed' && validSuitRevealPayload(gameId))
          || (request.resource.data.type == 'round/half-selected' && validHalfSelectionPayload(gameId))
          || (request.resource.data.type in ['power/activated', 'power/contributed', 'power/declined'] && validPowerPayload(gameId))
        );
    }

    match /games/{gameId}/events/{eventId} {
      // Trusted clients intentionally share the complete stream. The rules only
      // guarantee attribution and append-only history; they are not anti-cheat.
      allow read: if signedIn();
      allow create: if signedIn() && validEvent(gameId);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

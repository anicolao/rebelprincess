{
  "name": "rebel-princess",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "svelte-kit sync && husky",
    "dev": "vite dev --host 127.0.0.1 --port 5184 --strictPort",
    "dev:e2e": "vite dev --host 127.0.0.1 --port 5184 --strictPort",
    "build": "vite build",
    "preview": "vite preview --port 4184 --strictPort",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "firebase emulators:exec --project rebel-princess-e2e --only firestore \"playwright test\"",
    "test:e2e:update-snapshots": "firebase emulators:exec --project rebel-princess-e2e --only firestore \"playwright test --update-snapshots\"",
    "firebase": "firebase",
    "emulators": "firebase emulators:start",
    "rules:test": "firebase emulators:exec --only firestore 'true'",
    "test:rules": "firebase emulators:exec --project rebel-princess-e2e --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "verify:change": "bash scripts/verify-change.sh"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^26.1.1",
    "firebase-tools": "latest",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "firebase": "^12.16.0"
  }
}
